{
  "name": "@goalrate-app/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint configurations for GoalRate monorepo",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./react": "./react.js",
    "./library": "./library.js"
  },
  "files": [
    "*.js"
  ],
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "globals": "^17.2.0",
    "typescript-eslint": "^8.54.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    }
  }
}
