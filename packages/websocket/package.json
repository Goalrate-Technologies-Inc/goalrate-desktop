{
  "name": "@goalrate-app/websocket",
  "version": "0.1.0",
  "license": "BUSL-1.1",
  "description": "WebSocket connection manager for real-time sync and presence",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./offline": {
      "types": "./dist/offline/index.d.ts",
      "import": "./dist/offline/index.js",
      "require": "./dist/offline/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@goalrate-app/shared": "workspace:*",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@goalrate-app/eslint-config": "workspace:*",
    "@goalrate-app/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.10",
    "eslint": "^9.39.2",
    "jsdom": "^27.4.0",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=2.0.0",
    "@react-native-community/netinfo": ">=11.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    }
  }
}
