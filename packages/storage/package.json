{
  "name": "@goalrate-app/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Platform-agnostic storage adapter for Goalrate applications",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./interface": {
      "import": "./dist/interface.js",
      "require": "./dist/interface.cjs"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs"
    },
    "./desktop": {
      "import": "./dist/adapters/desktop/index.js",
      "require": "./dist/adapters/desktop/index.cjs"
    },
    "./web": {
      "import": "./dist/adapters/web/index.js",
      "require": "./dist/adapters/web/index.cjs"
    },
    "./native": {
      "import": "./dist/adapters/native/index.js",
      "require": "./dist/adapters/native/index.cjs"
    },
    "./memory": {
      "import": "./dist/adapters/memory/index.js",
      "require": "./dist/adapters/memory/index.cjs"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./team": {
      "import": "./dist/adapters/team/index.js",
      "require": "./dist/adapters/team/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@goalrate-app/crypto": "workspace:*",
    "@goalrate-app/shared": "workspace:*"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@tauri-apps/api": "^2.9.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "@tauri-apps/api": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@goalrate-app/eslint-config": "workspace:*",
    "@goalrate-app/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.10",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
