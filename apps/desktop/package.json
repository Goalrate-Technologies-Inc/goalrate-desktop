{
  "name": "@goalrate-app/desktop",
  "private": true,
  "version": "0.1.3",
  "license": "BUSL-1.1",
  "packageManager": "pnpm@8.15.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "prepare:appstore": "node ./scripts/prepare-appstore.mjs",
    "tauri:build:appstore": "pnpm run prepare:appstore && GOALRATE_APP_STORE_BUILD=true VITE_GOALRATE_APP_STORE_BUILD=true tauri build --bundles app --target universal-apple-darwin --config src-tauri/tauri.appstore.conf.json",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts --reporter verbose",
    "clean": "rm -rf dist src-tauri/target"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@goalrate-app/api-client": "workspace:*",
    "@goalrate-app/core": "workspace:*",
    "@goalrate-app/shared": "workspace:*",
    "@goalrate-app/storage": "workspace:*",
    "@goalrate-app/tailwind-config": "workspace:*",
    "@goalrate-app/ui": "workspace:*",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@goalrate-app/eslint-config": "workspace:*",
    "@goalrate-app/typescript-config": "workspace:*",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
